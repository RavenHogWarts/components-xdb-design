{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "./*.ts",
    "./*.tsx",
    "../src/**/*.ts",
    "../src/**/*.tsx"
  ]
}